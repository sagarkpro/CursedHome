# Auth0 SPA config — Vite exposes VITE_-prefixed vars to the browser.
# Copy this file to .env and fill in values from your Auth0 Application settings.
VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=your-spa-client-id
VITE_AUTH0_CALLBACK_URL=http://localhost:3000/callback
# sudox1 backend REST API base URL.
VITE_API_BASE_URL=https://api.sudox1.com
